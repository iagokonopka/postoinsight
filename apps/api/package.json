{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "pnpm --filter @postoinsight/shared build && pnpm --filter @postoinsight/db build && tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "worker": "tsx watch src/worker.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/core": "0.41.2",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/env": "^4.3.0",
    "@fastify/websocket": "^8.3.0",
    "@postoinsight/db": "workspace:*",
    "@postoinsight/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.27.0",
    "pg-boss": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}

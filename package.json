{
  "name": "postoinsight",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:agent": "pnpm --filter agent dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @postoinsight/db generate",
    "db:migrate": "pnpm --filter @postoinsight/db migrate",
    "db:seed": "pnpm --filter @postoinsight/db seed"
  }
}
